# Netlify Database proporciona la conexión automáticamente al desplegar.
# Solo define DATABASE_URL si conectas manualmente a otro PostgreSQL.
DATABASE_URL=

# Se usan únicamente al ejecutar manualmente `npm run db:seed`.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambiar-esta-clave

# Datos visibles en la web pública.
NEXT_PUBLIC_SERVER_NAME=Brújula Arcaica
NEXT_PUBLIC_SERVER_ADDRESS=Próximamente
NEXT_PUBLIC_SITE_URL=http://localhost:3000
